@{
}
@model Proyecto_Polleria.Models.temp.Actualizar_ProcesoTemp
<div class="container-fluid">
    <div class="row">
        <nav class="col-md-2">
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link active" data-bs-toggle="collapse" href="#menuRegistrar" role="button" aria-expanded="false" aria-controls="menuRegistrar">
                        Registrar ▾
                    </a>
                    <div class="collapse" id="menuRegistrar">
                        <ul class="nav flex-column ms-3">
                            <li class="nav-item"><a class="nav-link" asp-controller="Gestion_Movimiento_Venta" asp-action="Registrar_Ingreso">Registrar Ingreso</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Gestion_Movimiento_Venta" asp-action="Registrar_Pedido">Registrar Pedido</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Gestion_Movimiento_Venta" asp-action="Registrar_Salida">Registrar Salida</a></li>
                        </ul>
                    </div>
                </li>
                <li class="nav-item">
                    <a class="nav-link" data-bs-toggle="collapse" href="#menuConsultar" role="button" aria-expanded="false" aria-controls="menuConsultar">
                        Consultar ▾
                    </a>
                    <div class="collapse" id="menuConsultar">
                        <ul class="nav flex-column ms-3">
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Gestion_Movimiento_Venta" asp-action="Consultar_Servicios">Historial de Ventas</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Gestion_Movimiento_Venta" asp-action="Monitoreo_Cocina">Monitoreo Cocina</a>
                            </li>
                        </ul>
                    </div>
                </li>

                <li class="nav-item">
                    <a class="nav-link" data-bs-toggle="collapse" href="#menuActualizar" role="button" aria-expanded="false" aria-controls="menuActualizar">
                        Actualizar ▾
                    </a>
                    <div class="collapse" id="menuActualizar">
                        <ul class="nav flex-column ms-3">

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Gestion_Movimiento_Venta" asp-action="Actualizar_Proceso">Actualizar estado</a>
                            </li>
                        </ul>
                    </div>
                </li>

                <li class="nav-item">
                    <a class="nav-link" data-bs-toggle="collapse" href="#menuEliminar" role="button" aria-expanded="false" aria-controls="menuEliminar">
                        Eliminar ▾
                    </a>
                    <div class="collapse" id="menuEliminar">
                        <ul class="nav flex-column ms-3">
                            <
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Gestion_Movimiento_Venta" asp-action="Eliminar">Eliminar</a>
                                </li>
                            </ul>
                        </div>
                    </li>
                </ul>
            </nav>
        <div>
            <form asp-controller="Gestion_Movimiento_Venta" asp-action="ActualizarEstado" method="post">
                <fieldset>
                    <legend>Actualizar Estado del Pedido</legend>
                    <hr />

                    <!-- Selección de Mesa -->
                    <div>
                        <label>Seleccione la Mesa</label>
                        <select asp-for="id_mesa" asp-items="ViewBag.Mesas" 
                                onchange="this.form.action='/Gestion_Movimiento_Venta/Actualizar_Proceso'; this.form.submit();" required>
                            <option value="">-- Seleccione una mesa --</option>
                        </select>
                    </div>

                    <!-- Selección de Pedido -->
                    <div>
                        <label>Seleccione el Pedido</label>
                        <select asp-for="id_pedido" asp-items="ViewBag.Pedidos" required>
                            <option value="">-- Seleccione un pedido --</option>
                        </select>
                    </div>

                    <!-- Selección de Proceso -->
                    <div>
                        <label>Seleccione el Proceso / Estado</label>
                        <select asp-for="id_proceso" asp-items="ViewBag.Procesos" required>
                            <option value="">-- Seleccione un proceso --</option>
                        </select>
                    </div>

                    <br />
                    <button type="submit">Actualizar</button>
                </fieldset>
            </form>
        </div>
    </div>
</div>