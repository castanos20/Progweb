@{
}

<div class="container-fluid">
    <div class="row">
        <nav class="col-md-2">
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Gestion_inventario" asp-action="Registrar">Registrar</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Gestion_inventario" asp-action="Consultar">Consultar</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Gestion_inventario" asp-action="Actualizar">Actualizar</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link active" asp-controller="Gestion_inventario" asp-action="Eliminar">Eliminar</a>
                </li>
            </ul>
        </nav>

        <div class="col-md-10">
            <div class="mx-auto" style="width: 50%">
                <h3 class="mb-4">Eliminar Movimiento</h3>
                <form asp-controller="Gestion_inventario" asp-action="Eliminar" method="post">
                    <div class="mb-3">
                        <label class="form-label">ID del Movimiento</label>
                        <input type="number" name="id" class="form-control" placeholder="Ingrese ID..." required />
                    </div>
                    <button type="submit" class="btn btn-danger w-100">Eliminar</button>
                </form>

                <div class="mt-3">
                    @if (ViewBag.mensajeEliminar != null)
                    {
                        <div class="alert alert-danger" role="alert">@ViewBag.mensajeEliminar</div>
                    }
                    @if (ViewBag.mensajeEliminarExito != null)
                    {
                        <div class="alert alert-success" role="alert">@ViewBag.mensajeEliminarExito</div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>