@model Inventario
@{
    var ingredientes = ViewBag.ingredientes as List<Ingrediente> ?? new List<Ingrediente>();
}

<div class="container-fluid">
    <div class="row">
        <nav class="col-md-2">
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Gestion_inventario" asp-action="Registrar">Registrar</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Gestion_inventario" asp-action="Consultar">Consultar</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Gestion_inventario" asp-action="Actualizar">Actualizar</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Gestion_inventario" asp-action="Eliminar">Eliminar</a>
                </li>
            </ul>
        </nav>

        <div class="col-md-10">
            <div class="mx-auto" style="width: 50%">
                <h3 class="mb-4">Gestión de Inventario</h3>

                <ul class="nav nav-tabs" id="inventarioTab" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="ingreso-tab" data-bs-toggle="tab" data-bs-target="#ingreso" type="button" role="tab" aria-controls="ingreso" aria-selected="true">Registrar Ingreso</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="salida-tab" data-bs-toggle="tab" data-bs-target="#salida" type="button" role="tab" aria-controls="salida" aria-selected="false">Registrar Salida</button>
                    </li>
                </ul>

                <div class="tab-content border-start border-end border-bottom p-4 bg-light" id="inventarioTabContent">
                    <!-- Formulario de Ingreso -->
                    <div class="tab-pane fade show active" id="ingreso" role="tabpanel" aria-labelledby="ingreso-tab">
                        <form asp-controller="Gestion_inventario" asp-action="Registrar" method="post">
                            <input type="hidden" name="id_tipo_movimiento" value="1" />
                            <fieldset>
                                <legend class="h5">Ingreso de Inventario</legend>
                                <hr />
                                <div class="mb-3">
                                    <label class="form-label">Ingrediente</label>
                                    <select name="id_ingrediente" class="form-select" required>
                                        <option value="">Seleccione un ingrediente...</option>
                                        @foreach (var ing in ingredientes)
                                        {
                                            <option value="@ing.id">@ing.nombre (@ing.unidad_medida)</option>
                                        }
                                    </select>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Cantidad</label>
                                    <input type="number" step="0.01" name="cantidad" class="form-control" required />
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Precio Unitario</label>
                                    <input type="number" step="0.01" name="precio_unitario" class="form-control" required />
                                </div>
                                <button type="submit" class="btn btn-primary w-100">Registrar Ingreso</button>
                            </fieldset>
                        </form>
                    </div>

                    <!-- Formulario de Salida -->
                    <div class="tab-pane fade" id="salida" role="tabpanel" aria-labelledby="salida-tab">
                        <form asp-controller="Gestion_inventario" asp-action="Registrar" method="post">
                            <input type="hidden" name="id_tipo_movimiento" value="2" />
                            <input type="hidden" name="precio_unitario" value="0" />
                            <fieldset>
                                <legend class="h5">Salida de Inventario</legend>
                                <hr />
                                <div class="mb-3">
                                    <label class="form-label">Ingrediente</label>
                                    <select name="id_ingrediente" class="form-select" required>
                                        <option value="">Seleccione un ingrediente...</option>
                                        @foreach (var ing in ingredientes)
                                        {
                                            <option value="@ing.id">@ing.nombre (@ing.unidad_medida)</option>
                                        }
                                    </select>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label">Cantidad a Retirar</label>
                                    <input type="number" step="0.01" name="cantidad" class="form-control" required />
                                </div>
                                <button type="submit" class="btn btn-danger w-100">Registrar Salida</button>
                            </fieldset>
                        </form>
                    </div>
                </div>

                <div class="mt-3">
                    @if (ViewBag.mensajereg != null)
                    {
                        <div class="alert alert-success" role="alert">
                            @ViewBag.mensajereg
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
