@model Inventario
@{
    var ingredientes = ViewBag.ingredientes as List<Ingrediente> ?? new List<Ingrediente>();
}

<div class="container-fluid">
    <div class="row">
        <nav class="col-md-2">
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Gestion_inventario" asp-action="Registrar">Registrar</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Gestion_inventario" asp-action="Consultar">Consultar</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Gestion_inventario" asp-action="Actualizar">Actualizar</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Gestion_inventario" asp-action="Eliminar">Eliminar</a>
                </li>
            </ul>
        </nav>

        <div class="col-md-10">
            <div class="mx-auto" style="width: 50%">
                <h3 class="mb-4">Actualizar Movimiento de Inventario</h3>

                <form asp-controller="Gestion_inventario" asp-action="Actualizar" method="get" class="mb-4">
                    <div class="input-group">
                        <span class="input-group-text">ID de Movimiento</span>
                        <input type="number" name="id_buscar" class="form-control" placeholder="Ingrese ID a buscar..." required />
                        <button class="btn btn-primary" type="submit">Buscar</button>
                    </div>
                    @if (ViewBag.mensaje != null)
                    {
                        <div class="text-danger mt-2">@ViewBag.mensaje</div>
                    }
                    @if (ViewBag.mensajeExito != null)
                    {
                        <div class="text-success mt-2">@ViewBag.mensajeExito</div>
                    }
                </form>

                @if (Model != null)
                {
                    <ul class="nav nav-tabs" id="actualizarTab" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link @(Model.id_tipo_movimiento == 1 ? "active" : "disabled")" id="actualizar-ingreso-tab" data-bs-toggle="tab" data-bs-target="#actualizar-ingreso" type="button" role="tab" aria-controls="actualizar-ingreso" aria-selected="@(Model.id_tipo_movimiento == 1 ? "true" : "false")">Actualizar Ingreso</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link @(Model.id_tipo_movimiento == 2 ? "active" : "disabled")" id="actualizar-salida-tab" data-bs-toggle="tab" data-bs-target="#actualizar-salida" type="button" role="tab" aria-controls="actualizar-salida" aria-selected="@(Model.id_tipo_movimiento == 2 ? "true" : "false")">Actualizar Salida</button>
                        </li>
                    </ul>

                    <div class="tab-content border-start border-end border-bottom p-4 bg-light" id="actualizarTabContent">
                        <!-- Formulario Actualizar Ingreso -->
                        <div class="tab-pane fade @(Model.id_tipo_movimiento == 1 ? "show active" : "")" id="actualizar-ingreso" role="tabpanel" aria-labelledby="actualizar-ingreso-tab">
                            <form asp-controller="Gestion_inventario" asp-action="Actualizar" method="post">
                                <input type="hidden" asp-for="id" />
                                <input type="hidden" asp-for="id_tipo_movimiento" value="1" />
                                <fieldset>
                                    <legend class="h5">Modificar Ingreso</legend>
                                    <hr />
                                    <div class="mb-3">
                                        <label class="form-label">Ingrediente</label>
                                        <select asp-for="id_ingrediente" class="form-select" required>
                                            <option value="">Seleccione un ingrediente...</option>
                                            @foreach (var ing in ingredientes)
                                            {
                                                <option value="@ing.id">@ing.nombre (@ing.unidad_medida)</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Cantidad</label>
                                        <input type="number" step="0.01" asp-for="cantidad" class="form-control" required />
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Precio Unitario</label>
                                        <input type="number" step="0.01" asp-for="precio_unitario" class="form-control" required />
                                    </div>
                                    <button type="submit" class="btn btn-primary w-100">Guardar Cambios</button>
                                </fieldset>
                            </form>
                        </div>

                        <!-- Formulario Actualizar Salida -->
                        <div class="tab-pane fade @(Model.id_tipo_movimiento == 2 ? "show active" : "")" id="actualizar-salida" role="tabpanel" aria-labelledby="actualizar-salida-tab">
                            <form asp-controller="Gestion_inventario" asp-action="Actualizar" method="post">
                                <input type="hidden" asp-for="id" />
                                <input type="hidden" asp-for="id_tipo_movimiento" value="2" />
                                <input type="hidden" asp-for="precio_unitario" value="0" />
                                <fieldset>
                                    <legend class="h5">Modificar Salida</legend>
                                    <hr />
                                    <div class="mb-3">
                                        <label class="form-label">Ingrediente</label>
                                        <select asp-for="id_ingrediente" class="form-select" required>
                                            <option value="">Seleccione un ingrediente...</option>
                                            @foreach (var ing in ingredientes)
                                            {
                                                <option value="@ing.id">@ing.nombre (@ing.unidad_medida)</option>
                                            }
                                        </select>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Cantidad</label>
                                        <input type="number" step="0.01" asp-for="cantidad" class="form-control" required />
                                    </div>
                                    <button type="submit" class="btn btn-danger w-100">Guardar Cambios</button>
                                </fieldset>
                            </form>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
