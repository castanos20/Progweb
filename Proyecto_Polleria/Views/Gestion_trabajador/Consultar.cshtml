@model List<Trabajador>
@{
}
<div class="container-fluid">
    <div class="row">

        <nav class="col-md-2">
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Gestion_trabajador" asp-action="Registrar">Registrar</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Gestion_trabajador" asp-action="Consultar">Consultar</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Gestion_trabajador" asp-action="Eliminar">Eliminar</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Gestion_trabajador" asp-action="Actualizar">Actualizar</a>
                </li>
            </ul>
        </nav>

    </div>
</div>
<div>
    <div>
        <div class="col-md-10">
            <fieldset>
                <legend>Listado de Trabajadores</legend>
                <hr />
                <table class="table table-striped table-bordered">
                    <thead>
                        <tr>
                            <th>Cédula</th>
                            <th>Nombre Completo</th>
                            <th>Teléfono</th>
                            <th>Dirección</th>
                            <th>Salario</th>
                            <th>Función / Rol</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var trabajador in Model)
                            {
                                <tr>
                                    <td>@trabajador.cc</td>
                                    <td>@trabajador.nombre</td>
                                    <td>@trabajador.telefono</td>
                                    <td>@trabajador.direccion</td>
                                    <td>@trabajador.salario</td>
                                    <td>
                                        @(trabajador.rol == 1 ? "Mesero" : (trabajador.rol == 2 ? "Domiciliario" : (trabajador.rol == 3 ? "Cocinero" : "No asignado")))
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted">No hay trabajadores registrados.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </fieldset>
        </div>
    </div>
</div>
