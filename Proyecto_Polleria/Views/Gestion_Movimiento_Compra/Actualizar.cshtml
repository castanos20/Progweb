@model Proyecto_Polleria.Models.Movimiento_Compra
@{
}
<div class="container-fluid">
    <div class="row">
        <nav class="col-md-2">
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Gestion_Movimiento_Compra" asp-action="Registrar">Registrar</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Gestion_Movimiento_Compra" asp-action="Consultar">Consultar</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link active" asp-controller="Gestion_Movimiento_Compra" asp-action="Actualizar">Actualizar</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Gestion_Movimiento_Compra" asp-action="Eliminar">Eliminar</a>
                </li>
            </ul>
        </nav>

        <div class="col-md-10">
            <div class="mx-auto" style="width:40%">

                <form asp-controller="Gestion_Movimiento_Compra" asp-action="Actualizar" method="get">
                    <div>
                        <label>Ingrese ID de la compra a modificar</label>
                        <input type="number" name="id" class="form-control" required />
                        <br />
                        <button type="submit" class="btn btn-secondary">Buscar</button>
                    </div>
                    @if (ViewBag.mensaje != null && Model == null)
                    {
                        <div class="mt-2">
                            <label class="text-danger">@ViewBag.mensaje</label>
                        </div>
                    }
                </form>

                <hr />

                @if (Model != null)
                {
                    <form asp-controller="Gestion_Movimiento_Compra" asp-action="Actualizar" method="post">
                        <fieldset>
                            <legend>Actualizar Compra #@Model.id</legend>
                            <hr />

                            <input type="hidden" asp-for="id" />
                            <input type="hidden" asp-for="id_proveedor" />

                            <div class="mb-3">
                                <label class="form-label">Descripción</label>
                                <input asp-for="descripcion" type="text" class="form-control" required />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Método de Pago</label>
                                <select asp-for="id_metodo_pago" class="form-select" required>
                                    <option value="1">Efectivo</option>
                                    <option value="2">Tarjeta débito</option>
                                    <option value="3">Tarjeta crédito</option>
                                    <option value="4">Transferencia</option>
                                </select>
                            </div>

                            <button type="submit" class="btn btn-primary w-100">Actualizar</button>
                        </fieldset>
                    </form>

                    @if (ViewBag.mensaje != null)
                    {
                        <div class="mt-2">
                            <label class="text-success">@ViewBag.mensaje</label>
                        </div>
                    }
                }

            </div>
        </div>
    </div>
</div>
