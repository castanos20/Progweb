@model Proyecto_Polleria.Models.temp.Movimiento_CompraTemp
<div class="container-fluid">
    <div class="row">
        <nav class="col-md-2">
            <ul class="nav flex-column">
                <li class="nav-item">
                    <a class="nav-link active" asp-controller="Gestion_Movimiento_Compra" asp-action="Registrar">Registrar</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Gestion_Movimiento_Compra" asp-action="Consultar">Consultar</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Gestion_Movimiento_Compra" asp-action="Actualizar">Actualizar</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Gestion_Movimiento_Compra" asp-action="Eliminar">Eliminar</a>
                </li>
            </ul>
        </nav>

        <div class="col-md-10">
            <div class="mx-auto" style="width: 50%">
                <h3 class="mb-3">Registrar Compra</h3>

                <form asp-controller="Gestion_Movimiento_Compra" asp-action="Registrar" method="post">
                    <div class="mb-3">
                        <label class="form-label">Proveedor (NIT)</label>
                        <input type="text" asp-for="mc.id_proveedor" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Descripción</label>
                        <input type="text"  asp-for="mc.descripcion" class="form-control"  />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Método de Pago</label>
                        <select asp-for="mc.id_metodo_pago" class="form-select" required>
                            <option value="1">Efectivo</option>
                            <option value="2">Tarjeta débito</option>
                            <option value="3">Tarjeta crédito</option>
                            <option value="4">Transferencia</option>
                        </select>
                    </div>
                    
                    @if(!Model.Estado){
                        <button type="submit" class="btn btn-primary w-100">Continuar</button>
                    }
                </form>

                @if (Model.Estado == true)
                {
                    <hr />
                    <form asp-controller="Gestion_Movimiento_Compra" asp-action="AgregarPedido" method="post">
                        <input type="hidden" name="id_tipo_movimiento" value="1" />
                        <div class="mb-3">
                            <label class="form-label">Ingrediente</label>
                            <select name="id_ingrediente" class="form-select" required>
                                <option value="">Seleccione...</option>
                                @foreach (var ing in Model.ingredientes)
                                {
                                    <option value="@ing.id">@ing.nombre (@ing.unidad_medida)</option>
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Cantidad</label>
                            <input type="number" step="0.01" name="cantidad" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Precio Unitario</label>
                            <input type="number" step="0.01" name="precio_unitario" class="form-control" required />
                        </div>
                        <button type="submit" class="btn btn-secondary w-100">+ Agregar Ingrediente</button>
                    </form>

                    <table class="table table-sm table-striped mt-3">
                        <thead>
                            <tr>
                                <th>Ingrediente</th>
                                <th>Cantidad</th>
                                <th>Precio Unit.</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.pedidos != null)
                            {
                                @foreach (var item in Model.pedidos)
                                {
                                    <tr>
                                        <td>@item.nombre_ingrediente</td>
                                        <td>@item.cantidad</td>
                                        <td>@item.precio_unitario</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>

                    <form asp-controller="Gestion_Movimiento_Compra" asp-action="Confirmar" method="post">
                        <button type="submit" class="btn btn-success w-100">Confirmar Compra</button>
                    </form>
                }
            </div>
        </div>
    </div>
</div>